namespace strex

struct Point {
  x:int
  y:int

  fun Point(x:int, y:int) {
    this.x = x
    this.y = y
  }

  fun Sum(): int { return this.x + this.y }
  fun ToString(): string { return "(" + this.x + "," + this.y + ")" }
}

fun main() {
  p := new Point(1, 2)
  print(p.ToString())
  print(p.Sum())
}
