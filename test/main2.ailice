namespace TestSuite.IoNet

import io as io
import net.tls as tls
import net.http as http
import net.http.server as srv
import thread as th
import async as a

// 1. IO 测试：文件创建、写入、刷新、关闭与删除
fun testFileIo() {
  print("[IO] Starting file operations...")
  filename := "alice_temp_net_test.txt"
  
  f := io.create(filename)
  
  // 测试 Defer 的 LIFO 特性：
  // 先声明 remove，再声明 Close。
  // 退出时的执行顺序应该是：1. f.Close() -> 2. io.remove()
  defer io.remove(filename)
  defer f.Close()
  
  data := io.utf8Encode("Hello from Alice IO module! \n")
  f.Write(data)
  f.Flush()
  
  print("[IO] File write, flush, and defer cleanup registered successfully.")
  // 函数结束时，defer 触发，自动安全清理资源
}

// 2. TLS 测试
fun testTls() {
  print("[TLS] Running TLS smoke test...")
  // 调用你标准库里的 Smoke() 进行最小连通性验证
  tls.Smoke()
  print("[TLS] Smoke test passed.")
}

// 3. 入口函数
async fun main() {
  print("=== Starting Alice IO & Network Test ===")

  // --- 测试 1: 文件 IO ---
  testFileIo()

  // --- 测试 2: TLS ---
  testTls()

  // --- 测试 3: HTTP Server 与 Client ---
  print("[HTTP] Starting local server in a background thread...")

  // serveOnce 需要 (host, port, handler)，并返回实际监听端口。
  // 这里用 port=0 让系统自动分配端口，避免固定端口冲突。
  port := srv.serveOnce("127.0.0.1", 0, fun (req:http.Request): srv.HttpResponse {
    resp := new srv.HttpResponse()
    resp.status = 200
    resp.headers = ["Content-Type: text/plain; charset=utf-8"]
    resp.body = "ok"
    return resp
  })

  url := "http://127.0.0.1:" + port + "/"
  text := http.getText(url)
  print("[HTTP Client] got: " + text)
  
  print("=== IO & Network Test Completed ===")
  // 如果 serveOnce 是处理完一次请求就退出，线程会自动结束。
  // 如果是一直挂起，主进程结束时也会自然销毁。
}
